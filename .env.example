# ─────────────────────────────────────────────────────────────
#  Travel Booking Backend — Environment Configuration
#  Copy this file to `.env` and fill in your own values.
# ─────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed origins for CORS (the frontend URL)
CLIENT_URL=http://localhost:5173

# MongoDB — local or MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/travel-booking

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRES_IN=7d

# ─────────────── AI Provider ───────────────
# Which provider to use for extraction + itinerary generation.
# Options: gemini | openai | mock
#   - gemini : Google Gemini (multimodal, reads PDFs & images natively, generous free tier)
#   - openai : OpenAI GPT-4o (vision for images, text for PDFs)
#   - mock   : No API key needed. Returns realistic sample data so you can
#              demo the full flow without spending credits.
AI_PROVIDER=gemini

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─────────────── AWS S3 (document storage) ───────────────
# If these are left blank the server falls back to local disk storage
# (./uploads) so the app still runs without an AWS account.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=travel-booking-uploads
# Optional: a custom CDN / public base URL for objects
AWS_S3_PUBLIC_URL=
